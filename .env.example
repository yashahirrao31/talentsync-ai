# ─── Required — fill these in ──────────────────────────────────────────────────

# JWT — generate a strong 64+ character random string
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS_HERE_1234567890

# Google Gemini API Key (get from https://aistudio.google.com/)
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# AWS S3
AWS_S3_BUCKET=ats-resume-checker-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_SECRET_KEY

# ─── Optional — change only if needed ─────────────────────────────────────────

# PostgreSQL (local Docker)
DB_NAME=atscheck
DB_USER=postgres
DB_PASSWORD=postgres
